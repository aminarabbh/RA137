# ==============================================================================
# RA137 Reconnaissance Framework – Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for the services you use.
# All keys are optional – the tool will skip modules that require missing keys.
# ==============================================================================

# --- API Keys ----------------------------------------------------------------

SHODAN_API_KEY=
FOFA_EMAIL=
FOFA_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
SECURITYTRAILS_API_KEY=

# ipinfo.io Lite API token (free, unlimited – https://ipinfo.io/signup)
IPINFO_API_TOKEN=

# --- AI Report Generation ----------------------------------------------------
# Provider: "openai" or "ollama"
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
# For OpenAI:
OPENAI_API_KEY=
# For Ollama (local): set AI_PROVIDER=ollama, AI_MODEL=<model_name>
# AI_BASE_URL is auto-detected for Ollama (http://localhost:11434/v1)
AI_BASE_URL=
AI_API_KEY=
# Use AI to validate ASN recon and real-IP discovery results (true/false)
# When enabled, the AI reviews candidates to reduce false positives
AI_VALIDATION=true

# --- Telegram Alerts (optional) ----------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Concurrency / Timeouts --------------------------------------------------
MAX_WORKERS=50
MAX_CDN_WORKERS=20
MAX_API_WORKERS=10
MAX_CERT_WORKERS=100
MAX_SSL_WORKERS=50
CERT_DISCOVERY_WORKERS=100

HTTP_TIMEOUT=30
SSL_TIMEOUT=5
COMMAND_TIMEOUT=10000
API_TIMEOUT=60
NMAP_TIMEOUT=600

MAX_RETRIES=2
BACKOFF_FACTOR=2.0
HTTP_RETRIES=3

# --- Paths -------------------------------------------------------------------
OUTPUT_BASE=outputs
WORDLISTS_DIR=wordlists
CDN_FILE=wordlists/all_cdn.txt
TARGETS_FILE=targets.txt
LOG_FILE=outputs/recon.log
